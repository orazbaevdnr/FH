{
  "version": 2,
  "name": "freelance-hunter",
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/",         "dest": "/public/index.html" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.10",
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "crons": [
    { "path": "/api/parse-jobs",   "schedule": "*/15 * * * *" },
    { "path": "/api/analyze-jobs", "schedule": "*/16 * * * *" }
  ]
}
