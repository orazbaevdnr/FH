# Скопируй этот файл в .env и заполни реальными значениями
# cp .env.example .env

# ── Groq AI (получи на console.groq.com — бесплатно) ──────────────────────
GROQ_API_KEY=gsk_your_key_here

# ── Vercel KV (заполнится автоматически после `vercel kv create`) ──────────
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
